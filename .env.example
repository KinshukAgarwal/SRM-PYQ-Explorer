# Optional in production deployments; development uses Vite proxy via /api.
VITE_API_BASE_URL=https://srm-pyq-api.onrender.com

# Optional: if set, frontend builds permanent public PDF URLs as
# ${VITE_R2_PUBLIC_BASE_URL}/${object_key} when API public_url is null.
# Example: https://srm-pyqs-files.r2.dev
VITE_R2_PUBLIC_BASE_URL=
